using System;
using System.Collections.Generic;
using TwinCAT.Ads;
using TwinCAT.Ads.TypeSystem;
using TwinCAT.TypeSystem;

public static class TcMainSymbolSearch
{
    public static string? FindInMain(string amsNetId, int port, string targetName)
    {
        using var client = new AdsClient();
        client.Connect(amsNetId, port);

        ISymbolLoader loader = SymbolLoaderFactory.Create(client, SymbolLoaderSettings.Default);

        // Find top-level MAIN
        ISymbol? main = null;
        foreach (ISymbol s in loader.Symbols)
        {
            if (string.Equals(s.InstanceName, "MAIN", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(s.InstancePath, "MAIN", StringComparison.OrdinalIgnoreCase))
            {
                main = s;
                break;
            }
        }

        if (main == null)
            return null;

        // Optional: if user searches for MAIN itself
        if (string.Equals(targetName, "MAIN", StringComparison.OrdinalIgnoreCase))
            return main.InstancePath;

        // Search recursively under MAIN
        var match = FindByNameRecursive(main.SubSymbols, targetName);
        return match?.InstancePath; // e.g. MAIN.myStruct.myMember
    }

    private static ISymbol? FindByNameRecursive(IEnumerable<ISymbol> symbols, string targetName)
    {
        foreach (var s in symbols)
        {
            if (string.Equals(s.InstanceName, targetName, StringComparison.OrdinalIgnoreCase))
                return s;

            var child = FindByNameRecursive(s.SubSymbols, targetName);
            if (child != null)
                return child;
        }
        return null;
    }
}