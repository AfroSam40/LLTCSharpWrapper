public static PointCloud RigidTransform3D(PointCloud cloud, Transform transform)
{
    // 1) Extract to array (YOU decide best way)
    var pts = cloud.PointsArray; // ideally already an array for speed

    // 2) Convert your transform to RigidTf
    var rt = GpuRigidTransform.ToRigidTf(
        transform.r00, transform.r01, transform.r02,
        transform.r10, transform.r11, transform.r12,
        transform.r20, transform.r21, transform.r22,
        transform.tx,  transform.ty,  transform.tz,
        transform.s
    );

    // 3) Run GPU
    var outPts = GpuRigidTransform.RigidTransform3D_GPU(pts, rt);

    return new PointCloud(outPts);
}