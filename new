using System;
using System.Diagnostics;

class Program
{
    static void Main()
    {
        const int N = 100_000_000;
        double sum = 0;

        var sw = Stopwatch.StartNew();

        for (int i = 0; i < N; i++)
            sum += i * 0.000001;

        sw.Stop();

        Console.WriteLine($"Sum: {sum}");
        Console.WriteLine($"Elapsed: {sw.ElapsedMilliseconds} ms");
    }
}