using System;
using ILGPU;
using ILGPU.Runtime;

public struct ScanPointXYZ
{
    public double X, Y, Z;
    public ScanPointXYZ(double x, double y, double z) { X = x; Y = y; Z = z; }
}

public struct RigidTfD
{
    public double r00, r01, r02;
    public double r10, r11, r12;
    public double r20, r21, r22;
    public double tx, ty, tz;
    public double s;
}

public static class GpuRigidTransformD
{
    // Cache these; do NOT recreate per call
    private static readonly Context _ctx = Context.CreateDefault();
    private static readonly Accelerator _acc = _ctx.CreateDefaultAccelerator();
    private static readonly Action<Index1D, ArrayView<ScanPointXYZ>, ArrayView<ScanPointXYZ>, RigidTfD> _kernel
        = _acc.LoadAutoGroupedStreamKernel<Index1D, ArrayView<ScanPointXYZ>, ArrayView<ScanPointXYZ>, RigidTfD>(Kernel);

    private static void Kernel(Index1D i, ArrayView<ScanPointXYZ> src, ArrayView<ScanPointXYZ> dst, RigidTfD rt)
    {
        if (i >= src.Length) return;

        var p = src[i];
        double x = p.X, y = p.Y, z = p.Z;
        double s = rt.s;

        dst[i] = new ScanPointXYZ(
            s * (rt.r00 * x + rt.r01 * y + rt.r02 * z) + rt.tx,
            s * (rt.r10 * x + rt.r11 * y + rt.r12 * z) + rt.ty,
            s * (rt.r20 * x + rt.r21 * y + rt.r22 * z) + rt.tz
        );
    }

    public static ScanPointXYZ[] RigidTransform3D_GPU(ScanPointXYZ[] points, in RigidTfD rt)
    {
        if (points == null || points.Length == 0) return Array.Empty<ScanPointXYZ>();

        using var dSrc = _acc.Allocate1D<ScanPointXYZ>(points.Length);
        using var dDst = _acc.Allocate1D<ScanPointXYZ>(points.Length);

        dSrc.CopyFromCPU(points);
        _kernel(points.Length, dSrc.View, dDst.View, rt);
        _acc.Synchronize();

        var outPts = new ScanPointXYZ[points.Length];
        dDst.CopyToCPU(outPts);
        return outPts;
    }
}