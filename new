public async Task<string> UploadPointCloudBytesAsync(byte[] fileBytes, string fileName, CancellationToken ct = default)
{
    if (fileBytes == null || fileBytes.Length == 0) throw new ArgumentNullException(nameof(fileBytes));
    if (string.IsNullOrWhiteSpace(fileName)) throw new ArgumentNullException(nameof(fileName));

    string token = await GetAuthTokenAsync(ct).ConfigureAwait(false);

    using var fileContent = new ByteArrayContent(fileBytes);
    fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/octet-stream");

    using var form = new MultipartFormDataContent
    {
        { fileContent, "file", fileName },
        { new StringContent(fileName), "key" },
        { new StringContent(fileName), "DisplayName" }
    };

    using var req = new HttpRequestMessage(HttpMethod.Post, _fileUploadUrl);
    req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
    req.Content = form;

    using var resp = await _http.SendAsync(req, ct).ConfigureAwait(false);
    string body = await resp.Content.ReadAsStringAsync(ct).ConfigureAwait(false);
    resp.EnsureSuccessStatusCode();
    return body;
}