public static async Task<string> UploadPointCloudAsync(
    string fileName,
    PointCloud cloud,
    FactoryTelemetryClient telemetry,
    CancellationToken ct = default)
{
    Stopwatch sp = Stopwatch.StartNew();

    var points = cloud?.Points.ToArray() ?? throw new ArgumentNullException(nameof(cloud));
    fileName = EnsureExtension(fileName, ".pcd");

    int count = points.Length;
    int headerBytes = sizeof(int);
    int dataBytes = count * 3 * sizeof(float);
    byte[] raw = new byte[headerBytes + dataBytes];

    Buffer.BlockCopy(BitConverter.GetBytes(count), 0, raw, 0, sizeof(int));

    var packed = new float[count * 3];
    int xOff = 0, yOff = count, zOff = 2 * count;

    Parallel.For(0, count, i =>
    {
        var p = points[i];
        packed[xOff + i] = (float)p.X;
        packed[yOff + i] = (float)p.Y;
        packed[zOff + i] = (float)p.Z;
    });

    Buffer.BlockCopy(packed, 0, raw, headerBytes, dataBytes);

    byte[] compressed;
    using (var ms = new MemoryStream())
    {
        using (var brotli = new BrotliStream(ms, CompressionLevel.Fastest, leaveOpen: true))
            brotli.Write(raw, 0, raw.Length);

        compressed = ms.ToArray();
    }

    Debug.Print($"pack+compress time --- {sp.ElapsedMilliseconds} ms");

    string response = await telemetry.UploadPointCloudBytesAsync(compressed, fileName, ct);
    Debug.Print($"total upload time --- {sp.ElapsedMilliseconds} ms");

    return response;
}