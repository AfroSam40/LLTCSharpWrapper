public static void SavePointCloud(string filePath, PointCloud cloud)
{
    var points = cloud?.Points;
    if (points == null) throw new ArgumentNullException(nameof(cloud));

    filePath = EnsureExtension(filePath, ".pcd");

    int count = points.Count;
    byte[] raw = new byte[sizeof(int) + count * 3 * sizeof(float)];

    Buffer.BlockCopy(BitConverter.GetBytes(count), 0, raw, 0, sizeof(int));

    int offset = sizeof(int);
    for (int i = 0; i < count; i++)
    {
        Buffer.BlockCopy(BitConverter.GetBytes((float)points[i].X), 0, raw, offset, 4); offset += 4;
        Buffer.BlockCopy(BitConverter.GetBytes((float)points[i].Y), 0, raw, offset, 4); offset += 4;
        Buffer.BlockCopy(BitConverter.GetBytes((float)points[i].Z), 0, raw, offset, 4); offset += 4;
    }

    using var fs = new FileStream(filePath, FileMode.Create, FileAccess.Write, FileShare.None);
    using var brotli = new BrotliStream(fs, CompressionLevel.Optimal);
    brotli.Write(raw, 0, raw.Length);
}