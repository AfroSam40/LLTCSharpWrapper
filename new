using System;
using System.Collections.Generic;
using HelixToolkit.SharpDX;
using HelixToolkit.Wpf.SharpDX;
using SharpDX;
using D3DCull = SharpDX.Direct3D11.CullMode;

public static class SliceMeshDx
{
    // Assumes BlobSlice has:
    //   System.Windows.Media.Media3D.Point3D[] HullWorld
    //   System.Windows.Media.Media3D.Vector3D Normal
    //   double Z0, Z1
    //   System.Windows.Media.Media3D.Point3D CenterWorld

    public static MeshGeometryModel3D BuildHullSlicesMeshSharpDx(
        IEnumerable<BlobSlice> slices,
        Color4 color,
        float opacity = 0.3f,
        float thicknessScale = 1.0f,
        bool twoSided = true)
    {
        if (slices == null) return null;

        var positions = new Vector3Collection();
        var indices = new IntCollection();

        foreach (var slice in slices)
        {
            var hull = slice?.HullWorld;
            if (hull == null || hull.Length < 3) continue;

            var n = new Vector3((float)slice.Normal.X, (float)slice.Normal.Y, (float)slice.Normal.Z);
            if (n.LengthSquared() < 1e-12f) continue;
            n = Vector3.Normalize(n);

            float thickness = (float)((slice.Z1 - slice.Z0) * thicknessScale);
            if (thickness <= 0) continue;

            var centerMid = new Vector3((float)slice.CenterWorld.X, (float)slice.CenterWorld.Y, (float)slice.CenterWorld.Z);
            var offset = n * (0.5f * thickness);
            var centerBottom = centerMid - offset;
            var centerTop = centerMid + offset;

            int nHull = hull.Length;

            // Base index for this slice in the global buffers
            int baseIndex = positions.Count;

            // Vertex layout for this slice:
            // baseIndex + 0               = bottom center
            // baseIndex + 1..nHull        = bottom ring
            // baseIndex + nHull + 1       = top center
            // baseIndex + nHull + 2..end  = top ring

            positions.Add(centerBottom);
            for (int i = 0; i < nHull; i++)
            {
                var p = hull[i];
                positions.Add(new Vector3((float)p.X, (float)p.Y, (float)p.Z) - offset);
            }

            int bottomCenter = baseIndex + 0;
            int bottomStart = baseIndex + 1;

            // Bottom cap (fan)
            for (int i = 0; i < nHull; i++)
            {
                int i2 = bottomStart + i;
                int i3 = bottomStart + ((i + 1) % nHull);
                indices.Add(bottomCenter);
                indices.Add(i2);
                indices.Add(i3);
            }

            int topCenter = bottomStart + nHull;
            positions.Add(centerTop);

            int topStart = topCenter + 1;
            for (int i = 0; i < nHull; i++)
            {
                var p = hull[i];
                positions.Add(new Vector3((float)p.X, (float)p.Y, (float)p.Z) + offset);
            }

            // Top cap (fan) - flip winding
            for (int i = 0; i < nHull; i++)
            {
                int i2 = topStart + i;
                int i3 = topStart + ((i + 1) % nHull);
                indices.Add(topCenter);
                indices.Add(i3);
                indices.Add(i2);
            }

            // Side quads
            for (int i = 0; i < nHull; i++)
            {
                int b0 = bottomStart + i;
                int b1 = bottomStart + ((i + 1) % nHull);
                int t0 = topStart + i;
                int t1 = topStart + ((i + 1) % nHull);

                indices.Add(b0); indices.Add(b1); indices.Add(t1);
                indices.Add(b0); indices.Add(t1); indices.Add(t0);
            }
        }

        if (positions.Count < 3 || indices.Count < 3) return null;

        var mesh = new MeshGeometry3D
        {
            Positions = positions,
            Indices = indices
        };

        // Optional: compute normals if you need lighting to look correct
        // mesh.Normals = MeshGeometry3D.CalculateNormals(mesh.Positions, mesh.Indices);

        var mat = new PhongMaterial
        {
            DiffuseColor = new Color4(color.Red, color.Green, color.Blue, opacity),
            AmbientColor = new Color4(color.Red, color.Green, color.Blue, opacity) * 0.25f
        };

        return new MeshGeometryModel3D
        {
            Geometry = mesh,
            Material = mat,
            CullMode = twoSided ? D3DCull.None : D3DCull.Back,
            IsHitTestVisible = false
        };
    }
}