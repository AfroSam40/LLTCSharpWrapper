using System;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Threading.Tasks;

public static class PCP
{
    public static PointCloud VoxelDownSample(PointCloud cloud, double cellSize)
    {
        var pts = cloud?.Points;
        if (pts == null || pts.Count == 0 || cellSize <= 0) return cloud;

        double inv = 1.0 / cellSize;

        // "seen voxels" set: key -> dummy byte
        var seen = new ConcurrentDictionary<long, byte>(Environment.ProcessorCount, pts.Count / 8);
        var result = new ConcurrentBag<ScanPointXYZ>();

        Parallel.ForEach(pts, p =>
        {
            int ix = (int)Math.Floor(p.X * inv);
            int iy = (int)Math.Floor(p.Y * inv);
            int iz = (int)Math.Floor(p.Z * inv);

            // Pack 3 signed ints into one 64-bit key (stable + fast)
            long key =
                ((long)(ix & 0x1FFFFF) << 42) |
                ((long)(iy & 0x1FFFFF) << 21) |
                ((long)(iz & 0x1FFFFF));

            if (seen.TryAdd(key, 0))
                result.Add(p);
        });

        return new PointCloud(result);
    }
}