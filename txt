using System;
using System.Collections.Generic;
using System.Data;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Shapes;

namespace LLT
{
    public partial class Calibration : Window
    {
        public List<Path> cloudPaths;

        private DataTable srcDt;
        private DataTable dstDt;
        private DataTable srcDt2;
        private DataTable dstDt2;

        private DataTable activeDt;
        private DataGrid activeGrid;
        private string activeName = "";

        public Calibration(List<Path> cloudPaths)
        {
            InitializeComponent();

            this.cloudPaths = cloudPaths;

            this.Loaded += Calibration_Loaded;
        }

        private void Calibration_Loaded(object sender, RoutedEventArgs e)
        {
            srcDt = CreatePointTable();
            dstDt = CreatePointTable();
            srcDt2 = CreatePointTable();
            dstDt2 = CreatePointTable();

            dgSrc.ItemsSource = srcDt.DefaultView;
            dgDst.ItemsSource = dstDt.DefaultView;
            dgSrc2.ItemsSource = srcDt2.DefaultView;
            dgDst2.ItemsSource = dstDt2.DefaultView;

            Log("Calibration window loaded.");
        }

        private DataTable CreatePointTable()
        {
            DataTable dt = new DataTable();

            dt.Columns.Add("Index", typeof(int));
            dt.Columns.Add("X", typeof(double));
            dt.Columns.Add("Y", typeof(double));
            dt.Columns.Add("Width", typeof(double));
            dt.Columns.Add("Height", typeof(double));

            return dt;
        }

        private void BtnSrcStartRec_Click(object sender, RoutedEventArgs e)
        {
            Button btn = sender as Button;
            if (btn == null) return;

            switch (btn.Name)
            {
                case "BtnSrcStartRec":
                    activeDt = srcDt;
                    activeGrid = dgSrc;
                    activeName = "SRC 1";
                    break;

                case "BtnDstStartRec":
                    activeDt = dstDt;
                    activeGrid = dgDst;
                    activeName = "DST 1";
                    break;

                case "BtnSrcStartRec2":
                    activeDt = srcDt2;
                    activeGrid = dgSrc2;
                    activeName = "SRC 2";
                    break;

                case "BtnDstStartRec2":
                    activeDt = dstDt2;
                    activeGrid = dgDst2;
                    activeName = "DST 2";
                    break;
            }

            Log($"Recording target set to {activeName}");
        }

        private void BtnDeleteSel_Click(object sender, RoutedEventArgs e)
        {
            Button btn = sender as Button;
            if (btn == null) return;

            DataGrid grid = GetGridFromButton(btn.Name);

            if (grid == null)
            {
                Log($"Delete failed. Unknown button: {btn.Name}");
                return;
            }

            if (grid.SelectedItem == null)
            {
                Log("Delete failed. No row selected.");
                return;
            }

            DataRowView rowView = grid.SelectedItem as DataRowView;

            if (rowView != null)
            {
                rowView.Row.Delete();
                ReIndex(GetTableFromGrid(grid));
                Log($"Deleted selected row from {grid.Name}");
            }
        }

        private void BtnClearAll_Click(object sender, RoutedEventArgs e)
        {
            Button btn = sender as Button;
            if (btn == null) return;

            DataTable dt = GetTableFromButton(btn.Name);

            if (dt == null)
            {
                Log($"Clear failed. Unknown button: {btn.Name}");
                return;
            }

            dt.Clear();
            Log($"Cleared table for {btn.Name}");
        }

        private DataGrid GetGridFromButton(string buttonName)
        {
            switch (buttonName)
            {
                case "BtnSrcDeleteSel":
                    return dgSrc;

                case "BtnDstDeleteSel":
                    return dgDst;

                case "BtnSrcDeleteSel2":
                    return dgSrc2;

                case "BtnDstDeleteSel2":
                    return dgDst2;

                default:
                    return null;
            }
        }

        private DataTable GetTableFromButton(string buttonName)
        {
            switch (buttonName)
            {
                case "BtnSrcClearAll":
                    return srcDt;

                case "BtnDstClearAll":
                    return dstDt;

                case "BtnSrcClearAll2":
                    return srcDt2;

                case "BtnDstClearAll2":
                    return dstDt2;

                default:
                    return null;
            }
        }

        private DataTable GetTableFromGrid(DataGrid grid)
        {
            if (grid == dgSrc) return srcDt;
            if (grid == dgDst) return dstDt;
            if (grid == dgSrc2) return srcDt2;
            if (grid == dgDst2) return dstDt2;

            return null;
        }

        private void ReIndex(DataTable dt)
        {
            if (dt == null) return;

            for (int i = 0; i < dt.Rows.Count; i++)
            {
                dt.Rows[i]["Index"] = i;
            }
        }

        public void AddRecordedRect(double x, double y, double width, double height)
        {
            if (activeDt == null)
            {
                Log("No active recording table selected.");
                return;
            }

            int index = activeDt.Rows.Count;

            activeDt.Rows.Add(index, x, y, width, height);

            activeGrid?.ScrollIntoView(activeGrid.Items[activeGrid.Items.Count - 1]);

            Log($"Added rect to {activeName}: X={x:F3}, Y={y:F3}, W={width:F3}, H={height:F3}");
        }

        public void Log(string msg)
        {
            string line = $"{DateTime.Now:HH:mm:ss.fff}  {msg}{Environment.NewLine}";

            if (!Dispatcher.CheckAccess())
            {
                Dispatcher.Invoke(() => Log(msg));
                return;
            }

            tbDebugTextBox.AppendText(line);
            tbDebugTextBox.ScrollToEnd();
        }
    }
}