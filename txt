public static BuildCloudGpuResult ConstructJoinedCloud_GPU(
    RawProfileInfo leftRaw,
    RawProfileInfo rightRaw,
    double yInterval,
    RigidT rightToLeftTransform,
    bool invertRequired)
{
    var left = FlattenRawProfileInfo(leftRaw, nameof(leftRaw));
    var right = FlattenRawProfileInfo(rightRaw, nameof(rightRaw));

    int maxValidCount = left.TotalRawCount + right.TotalRawCount;
    int maxNullCount = left.TotalRawCount + right.TotalRawCount;

    if (maxValidCount == 0)
    {
        return new BuildCloudGpuResult(
            new PointCloud(Array.Empty<ScanPointXYZ>()),
            new List<(ScanPointXYZ Point, nullTypes reason)>());
    }

    RigidT rt = rightToLeftTransform;

    // Adjust right transform for inverted scan.
    if (invertRequired)
        rt.ty = -rt.ty;

    RigidT identity = new RigidT
    {
        r00 = 1, r01 = 0, r02 = 0,
        r10 = 0, r11 = 1, r12 = 0,
        r20 = 0, r21 = 0, r22 = 1,
        tx = 0, ty = 0, tz = 0,
        s = 1
    };

    // CPU -> GPU uploads.
    using var dLeftRawZ = _acc.Allocate1D(left.RawZ.Length == 0 ? new int[1] : left.RawZ);
    using var dLeftProfileIndex = _acc.Allocate1D(left.ProfileIndexPerPoint.Length == 0 ? new int[1] : left.ProfileIndexPerPoint);
    using var dLeftProfileInfos = _acc.Allocate1D(left.ProfileInfos.Length == 0 ? new RawProfileInfoGpu[1] : left.ProfileInfos);

    using var dRightRawZ = _acc.Allocate1D(right.RawZ.Length == 0 ? new int[1] : right.RawZ);
    using var dRightProfileIndex = _acc.Allocate1D(right.ProfileIndexPerPoint.Length == 0 ? new int[1] : right.ProfileIndexPerPoint);
    using var dRightProfileInfos = _acc.Allocate1D(right.ProfileInfos.Length == 0 ? new RawProfileInfoGpu[1] : right.ProfileInfos);

    using var dJoined = _acc.Allocate1D<ScanPointXYZ>(Math.Max(1, maxValidCount));
    using var dNulls = _acc.Allocate1D<NullPointGpu>(Math.Max(1, maxNullCount));

    // counts[0] = valid joined count, counts[1] = null count
    using var dCounts = _acc.Allocate1D(new int[2]);

    // Left raw -> joined cloud, no transform.
    if (left.TotalRawCount > 0)
    {
        _rawToJoinedKernel(
            left.TotalRawCount,
            dLeftRawZ.View,
            dLeftProfileIndex.View,
            dLeftProfileInfos.View,
            dJoined.View,
            dNulls.View,
            dCounts.View,
            yInterval,
            identity,
            0);
    }

    // Right raw -> transform -> append into joined cloud.
    if (right.TotalRawCount > 0)
    {
        _rawToJoinedKernel(
            right.TotalRawCount,
            dRightRawZ.View,
            dRightProfileIndex.View,
            dRightProfileInfos.View,
            dJoined.View,
            dNulls.View,
            dCounts.View,
            yInterval,
            rt,
            1);
    }

    _acc.Synchronize();

    // Small count readback.
    int[] counts = dCounts.GetAsArray1D();
    int validCount = counts[0];
    int nullCount = counts[1];

    // Invert only valid joined cloud. Do not process null points.
    if (invertRequired && validCount > 0)
    {
        double centerY = GetCenterYOnGpu(dJoined, validCount);

        _invertYKernel(
            validCount,
            dJoined.View.SubView(0, validCount),
            centerY);

        _acc.Synchronize();
    }

    // GPU -> CPU final downloads.
    ScanPointXYZ[] joinedPoints = dJoined.GetAsArray1D()
        .Take(validCount)
        .ToArray();

    var nullPoints = dNulls.GetAsArray1D()
        .Take(nullCount)
        .Select(n => (n.Point, n.Reason))
        .ToList();

    return new BuildCloudGpuResult(
        new PointCloud(joinedPoints),
        nullPoints);
}