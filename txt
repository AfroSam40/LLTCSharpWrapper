PROGRAM MAIN
VAR
    // Command inputs
    bCmdWriteOutlet     : BOOL;     // pulse TRUE for one cycle to command outlet
    bCmdWriteOutletOld  : BOOL;
    bWriteExecute       : BOOL;

    bOutletOnCmd        : BOOL := TRUE;  // TRUE = turn outlet ON, FALSE = turn outlet OFF
    nOutletNumber       : UINT := 1;     // outlet number: 1, 2, 3, ...

    // Modbus TCP settings
    sPduIp              : STRING(15) := '192.168.1.50';

    // Direct PDU = 502
    // PX4 port-forwarding:
    // Primary = 50600, Secondary 1 = 50601, Secondary 2 = 50602, etc.
    nPduPort            : UINT := 502;

    nUnitId             : BYTE := 16#FF;

    // Modbus coil write FB
    fbWriteOutletCoil   : FB_MBWriteSingleCoil;

    // Calculated Modbus values
    nCoilAddr           : WORD;
    nCoilValue          : WORD;

    // Status
    bBusy               : BOOL;
    bError              : BOOL;
    nErrId              : UDINT;
END_VAR


// Rising edge command
bWriteExecute := bCmdWriteOutlet AND NOT bCmdWriteOutletOld;
bCmdWriteOutletOld := bCmdWriteOutlet;


// Calculate outlet coil address
// Outlet 1 = 16#0100
// Outlet 2 = 16#0101
// Outlet 3 = 16#0102
IF nOutletNumber >= 1 THEN
    nCoilAddr := WORD#16#0100 + UINT_TO_WORD(nOutletNumber - 1);
ELSE
    nCoilAddr := WORD#16#0100; // fallback to outlet 1
END_IF;


// Modbus coil value
// Beckhoff FB_MBWriteSingleCoil uses:
// 16#FF00 = ON
// 16#0000 = OFF
IF bOutletOnCmd THEN
    nCoilValue := WORD#16#FF00;
ELSE
    nCoilValue := WORD#16#0000;
END_IF;


// Write outlet relay coil
fbWriteOutletCoil(
    sIPAddr   := sPduIp,
    nTCPPort  := nPduPort,
    nUnitID   := nUnitId,
    nMBAddr   := nCoilAddr,
    nValue    := nCoilValue,
    bExecute  := bWriteExecute,
    tTimeout  := T#2S,
    bBusy     => bBusy,
    bError    => bError,
    nErrId    => nErrId
);