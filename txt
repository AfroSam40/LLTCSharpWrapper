PROGRAM MAIN
VAR
    // Trigger this TRUE for one PLC cycle to start the read
    bReadTrigger    : BOOL := FALSE;
    bReadTrigOld    : BOOL := FALSE;
    bReadExecute    : BOOL := FALSE;

    // Modbus TCP read FB
    fbReadReg       : FB_MBReadRegs;

    // PDU connection settings
    sPduIp          : STRING(15) := '192.168.1.50';

    // Use 502 for direct PDU connection.
    // Use 50600, 50601, 50602, etc. for PX4 port-forwarding mode.
    nPduPort        : UINT := 502;

    // For direct Modbus TCP device access, Beckhoff says Unit ID can be 16#FF
    nUnitId         : BYTE := 16#FF;

    // PX4 register to read
    nRegisterAddr   : WORD := 2048; // 0x0800
    nQuantity       : WORD := 1;    // one 16-bit holding register

    // Destination buffer
    arrRegs         : ARRAY[0..0] OF WORD;

    // Result
    wPeripheral1SensorType : WORD;

    // Status
    bBusy           : BOOL;
    bError          : BOOL;
    nErrId          : UDINT;
    cbRead          : UDINT;
    bDone           : BOOL;
END_VAR


// Rising edge detection for read command
bReadExecute := bReadTrigger AND NOT bReadTrigOld;
bReadTrigOld := bReadTrigger;


// Call Modbus read holding registers FB
fbReadReg(
    sIPAddr   := sPduIp,
    nTCPPort  := nPduPort,
    nUnitID   := nUnitId,
    nQuantity := nQuantity,
    nMBAddr   := nRegisterAddr,
    cbLength  := SIZEOF(arrRegs),
    pDestAddr := ADR(arrRegs),
    bExecute  := bReadExecute,
    tTimeout  := T#2S,
    bBusy     => bBusy,
    bError    => bError,
    nErrId    => nErrId,
    cbRead    => cbRead
);


// Latch result when read finishes successfully
IF NOT bBusy AND NOT bError AND cbRead = SIZEOF(arrRegs) THEN
    wPeripheral1SensorType := arrRegs[0];
    bDone := TRUE;
END_IF