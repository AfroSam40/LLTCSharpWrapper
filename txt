    // Your corrected raw input shape
    public struct RawProfileInfo
    {
        public List<int[]> rawProfiles;          // original raw arrays, not used by GPU method
        public List<ProfileData> profilesData;   // converted ProfileData used by GPU method
    }

    public struct RawProfileInfoGpu
    {
        public int ProfileIndex;     // row/profile index used for Y
        public int DataStart;        // start index inside flattened rawZ
        public int Count;            // ProfInfo.nProfileDataCount
        public double XPitch;        // ProfInfo.LXPitch / 100000.0
    }

    public struct NullPointGpu
    {
        public ScanPointXYZ Point;
        public nullTypes Reason;
    }

    public struct BuildCloudGpuResult
    {
        public PointCloud Cloud;
        public List<(ScanPointXYZ Point, nullTypes reason)> NullPoints;

        public BuildCloudGpuResult(
            PointCloud cloud,
            List<(ScanPointXYZ Point, nullTypes reason)> nullPoints)
        {
            Cloud = cloud;
            NullPoints = nullPoints;
        }
    }

    private struct FlatRawGpuInput
    {
        public int[] RawZ;
        public int[] ProfileIndexPerPoint;
        public RawProfileInfoGpu[] ProfileInfos;
        public int TotalRawCount;
    }

    private static readonly Action<
        Index1D,
        ArrayView<int>,
        ArrayView<int>,
        ArrayView<RawProfileInfoGpu>,
        ArrayView<ScanPointXYZ>,
        ArrayView<NullPointGpu>,
        ArrayView<int>,
        double,
        RigidT,
        int> _rawToJoinedKernel =
            _acc.LoadAutoGroupedStreamKernel<
                Index1D,
                ArrayView<int>,
                ArrayView<int>,
                ArrayView<RawProfileInfoGpu>,
                ArrayView<ScanPointXYZ>,
                ArrayView<NullPointGpu>,
                ArrayView<int>,
                double,
                RigidT,
                int>(RawToJoinedKernel);

    private static readonly Action<
        Index1D,
        ArrayView<ScanPointXYZ>,
        ArrayView<double>,
        ArrayView<double>,
        int> _reduceMinMaxYKernel =
            _acc.LoadAutoGroupedStreamKernel<
                Index1D,
                ArrayView<ScanPointXYZ>,
                ArrayView<double>,
                ArrayView<double>,
                int>(ReduceMinMaxYKernel);

    private static readonly Action<
        Index1D,
        ArrayView<ScanPointXYZ>,
        double> _invertYKernel =
            _acc.LoadAutoGroupedStreamKernel<
                Index1D,
                ArrayView<ScanPointXYZ>,
                double>(InvertYKernel);

    private static void RawToJoinedKernel(
        Index1D rawIndex,
        ArrayView<int> rawZ,
        ArrayView<int> profileIndexPerPoint,
        ArrayView<RawProfileInfoGpu> profileInfos,
        ArrayView<ScanPointXYZ> joinedValidPoints,
        ArrayView<NullPointGpu> nullPoints,
        ArrayView<int> counts,
        double yInterval,
        RigidT rt,
        int applyTransform)
    {
        int i = rawIndex;
        if (i >= rawZ.Length)
            return;

        int profileIndex = profileIndexPerPoint[i];
        var info = profileInfos[profileIndex];

        int localIndex = i - info.DataStart;
        int raw = rawZ[i];

        double x = localIndex * info.XPitch;
        double y = info.ProfileIndex * yInterval;

        bool isNull =
            raw == (int)nullTypes.Invalid1 ||
            raw == (int)nullTypes.Invalid2 ||
            raw == (int)nullTypes.Deadzone ||
            raw == (int)nullTypes.JudgmentStandby;

        if (isNull)
        {
            int nullIdx = Atomic.Add(ref counts[1], 1);

            nullPoints[nullIdx] = new NullPointGpu
            {
                Point = new ScanPointXYZ(x, y, 0.0),
                Reason = (nullTypes)raw
            };

            return;
        }

        var p = new ScanPointXYZ(x, y, raw / 100000.0);

        if (applyTransform == 1)
        {
            double px = p.X;
            double py = p.Y;
            double pz = p.Z;
            double s = rt.s;

            p = new ScanPointXYZ(
                s * (rt.r00 * px + rt.r01 * py + rt.r02 * pz) + rt.tx,
                s * (rt.r10 * px + rt.r11 * py + rt.r12 * pz) + rt.ty,
                s * (rt.r20 * px + rt.r21 * py + rt.r22 * pz) + rt.tz);
        }

        int validIdx = Atomic.Add(ref counts[0], 1);
        joinedValidPoints[validIdx] = p;
    }

    private static void ReduceMinMaxYKernel(
        Index1D blockIndex,
        ArrayView<ScanPointXYZ> points,
        ArrayView<double> blockMinY,
        ArrayView<double> blockMaxY,
        int validCount)
    {
        const int blockSize = 1024;

        int start = blockIndex * blockSize;
        int endCandidate = start + blockSize;
        int end = endCandidate < validCount ? endCandidate : validCount;

        double minY = double.PositiveInfinity;
        double maxY = double.NegativeInfinity;

        for (int i = start; i < end; i++)
        {
            double y = points[i].Y;

            if (y < minY) minY = y;
            if (y > maxY) maxY = y;
        }

        blockMinY[blockIndex] = minY;
        blockMaxY[blockIndex] = maxY;
    }

    private static void InvertYKernel(
        Index1D i,
        ArrayView<ScanPointXYZ> points,
        double centerY)
    {
        if (i >= points.Length)
            return;

        var p = points[i];
        p.Y = 2.0 * centerY - p.Y;
        points[i] = p;
    }

    public static BuildCloudGpuResult ConstructJoinedCloud_GPU(
        RawProfileInfo leftRaw,
        RawProfileInfo rightRaw,
        double yInterval,
        RigidT rightToLeftTransform,
        bool invertRequired)
    {
        var left = FlattenRawProfileInfo(leftRaw, nameof(leftRaw));
        var right = FlattenRawProfileInfo(rightRaw, nameof(rightRaw));

        int maxValidCount = left.TotalRawCount + right.TotalRawCount;
        int maxNullCount = left.TotalRawCount + right.TotalRawCount;

        if (maxValidCount == 0)
        {
            return new BuildCloudGpuResult(
                new PointCloud(Array.Empty<ScanPointXYZ>()),
                new List<(ScanPointXYZ Point, nullTypes reason)>());
        }

        RigidT rt = rightToLeftTransform;

        if (invertRequired)
            rt.ty = -rt.ty;

        RigidT identity = new RigidT
        {
            r00 = 1, r01 = 0, r02 = 0,
            r10 = 0, r11 = 1, r12 = 0,
            r20 = 0, r21 = 0, r22 = 1,
            tx = 0, ty = 0, tz = 0,
            s = 1
        };

        using var dLeftRawZ = _acc.Allocate1D(left.RawZ.Length == 0 ? new int[1] : left.RawZ);
        using var dLeftProfileIndex = _acc.Allocate1D(left.ProfileIndexPerPoint.Length == 0 ? new int[1] : left.ProfileIndexPerPoint);
        using var dLeftProfileInfos = _acc.Allocate1D(left.ProfileInfos.Length == 0 ? new RawProfileInfoGpu[1] : left.ProfileInfos);

        using var dRightRawZ = _acc.Allocate1D(right.RawZ.Length == 0 ? new int[1] : right.RawZ);
        using var dRightProfileIndex = _acc.Allocate1D(right.ProfileIndexPerPoint.Length == 0 ? new int[1] : right.ProfileIndexPerPoint);
        using var dRightProfileInfos = _acc.Allocate1D(right.ProfileInfos.Length == 0 ? new RawProfileInfoGpu[1] : right.ProfileInfos);

        using var dJoined = _acc.Allocate1D<ScanPointXYZ>(Math.Max(1, maxValidCount));
        using var dNulls = _acc.Allocate1D<NullPointGpu>(Math.Max(1, maxNullCount));

        // counts[0] = valid joined count
        // counts[1] = null count
        using var dCounts = _acc.Allocate1D(new int[2]);

        if (left.TotalRawCount > 0)
        {
            _rawToJoinedKernel(
                left.TotalRawCount,
                dLeftRawZ.View,
                dLeftProfileIndex.View,
                dLeftProfileInfos.View,
                dJoined.View,
                dNulls.View,
                dCounts.View,
                yInterval,
                identity,
                0);
        }

        if (right.TotalRawCount > 0)
        {
            _rawToJoinedKernel(
                right.TotalRawCount,
                dRightRawZ.View,
                dRightProfileIndex.View,
                dRightProfileInfos.View,
                dJoined.View,
                dNulls.View,
                dCounts.View,
                yInterval,
                rt,
                1);
        }

        _acc.Synchronize();

        int[] counts = dCounts.GetAsArray1D();
        int validCount = counts[0];
        int nullCount = counts[1];

        if (invertRequired && validCount > 0)
        {
            double centerY = GetCenterYOnGpu(dJoined, validCount);

            _invertYKernel(
                validCount,
                dJoined.View.SubView(0, validCount),
                centerY);

            _acc.Synchronize();
        }

        ScanPointXYZ[] joinedPoints = dJoined.GetAsArray1D()
            .Take(validCount)
            .ToArray();

        var nullPoints = dNulls.GetAsArray1D()
            .Take(nullCount)
            .Select(n => (n.Point, n.Reason))
            .ToList();

        return new BuildCloudGpuResult(
            new PointCloud(joinedPoints),
            nullPoints);
    }

    private static FlatRawGpuInput FlattenRawProfileInfo(RawProfileInfo rawInfo, string name)
    {
        if (rawInfo.profilesData == null)
            throw new ArgumentNullException($"{name}.{nameof(rawInfo.profilesData)}");

        int profileCount = rawInfo.profilesData.Count;

        if (profileCount == 0)
        {
            return new FlatRawGpuInput
            {
                RawZ = Array.Empty<int>(),
                ProfileIndexPerPoint = Array.Empty<int>(),
                ProfileInfos = Array.Empty<RawProfileInfoGpu>(),
                TotalRawCount = 0
            };
        }

        int totalRawCount = 0;

        for (int p = 0; p < profileCount; p++)
        {
            var pd = rawInfo.profilesData[p];
            int count = pd.ProfInfo.nProfileDataCount;

            if (count < 0)
                throw new InvalidOperationException($"{name} profile {p} has negative nProfileDataCount.");

            if (pd.ProfData == null)
                throw new InvalidOperationException($"{name} profile {p} ProfData is null.");

            if (pd.ProfData.Length < count)
                throw new InvalidOperationException($"{name} profile {p} ProfData length is smaller than nProfileDataCount.");

            totalRawCount += count;
        }

        var rawZ = new int[totalRawCount];
        var profileIndexPerPoint = new int[totalRawCount];
        var profileInfos = new RawProfileInfoGpu[profileCount];

        int offset = 0;

        for (int p = 0; p < profileCount; p++)
        {
            var pd = rawInfo.profilesData[p];

            int count = pd.ProfInfo.nProfileDataCount;
            double xPitch = ((double)pd.ProfInfo.LXPitch) / 100000.0;

            Array.Copy(pd.ProfData, 0, rawZ, offset, count);

            profileInfos[p] = new RawProfileInfoGpu
            {
                ProfileIndex = p,
                DataStart = offset,
                Count = count,
                XPitch = xPitch
            };

            for (int i = 0; i < count; i++)
                profileIndexPerPoint[offset + i] = p;

            offset += count;
        }

        return new FlatRawGpuInput
        {
            RawZ = rawZ,
            ProfileIndexPerPoint = profileIndexPerPoint,
            ProfileInfos = profileInfos,
            TotalRawCount = totalRawCount
        };
    }

    private static double GetCenterYOnGpu(
        MemoryBuffer1D<ScanPointXYZ, Stride1D.Dense> dPoints,
        int validCount)
    {
        if (validCount <= 0)
            return 0.0;

        const int blockSize = 1024;
        int blockCount = (validCount + blockSize - 1) / blockSize;

        using var dBlockMin = _acc.Allocate1D<double>(blockCount);
        using var dBlockMax = _acc.Allocate1D<double>(blockCount);

        _reduceMinMaxYKernel(
            blockCount,
            dPoints.View,
            dBlockMin.View,
            dBlockMax.View,
            validCount);

        _acc.Synchronize();

        double[] minYs = dBlockMin.GetAsArray1D();
        double[] maxYs = dBlockMax.GetAsArray1D();

        double minY = double.PositiveInfinity;
        double maxY = double.NegativeInfinity;

        for (int i = 0; i < blockCount; i++)
        {
            if (minYs[i] < minY) minY = minYs[i];
            if (maxYs[i] > maxY) maxY = maxYs[i];
        }

        return 0.5 * (minY + maxY);
    }
}