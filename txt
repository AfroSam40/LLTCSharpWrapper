using System;
using System.Collections.Generic;
using System.IO;
using Newtonsoft.Json;

public class JsonManager
{
    private readonly string _filePath;
    private Dictionary<string, object> _data;

    private static readonly JsonSerializerSettings Settings = new JsonSerializerSettings
    {
        Formatting = Formatting.Indented,
        TypeNameHandling = TypeNameHandling.Auto
    };

    public JsonManager(string filePathOrName)
    {
        if (string.IsNullOrWhiteSpace(filePathOrName))
            throw new ArgumentException("File path or name cannot be null or empty.", nameof(filePathOrName));

        _filePath = ResolveFilePath(filePathOrName);
        _data = new Dictionary<string, object>();

        Load();
    }

    private string ResolveFilePath(string filePathOrName)
    {
        string path = filePathOrName;

        bool hasDirectory = !string.IsNullOrWhiteSpace(Path.GetDirectoryName(path));

        if (!hasDirectory)
        {
            path = Path.Combine(AppContext.BaseDirectory, path);
        }

        if (Path.GetExtension(path) == string.Empty)
        {
            path += ".json";
        }

        return path;
    }

    private void Load()
    {
        if (!File.Exists(_filePath))
        {
            _data = new Dictionary<string, object>();
            return;
        }

        string json = File.ReadAllText(_filePath);

        if (string.IsNullOrWhiteSpace(json))
        {
            _data = new Dictionary<string, object>();
            return;
        }

        _data = JsonConvert.DeserializeObject<Dictionary<string, object>>(json, Settings)
                ?? new Dictionary<string, object>();
    }

    public void Save<T>(string name, T data, bool overwrite = false)
    {
        if (string.IsNullOrWhiteSpace(name))
            throw new ArgumentException("Save name cannot be null or empty.", nameof(name));

        if (_data.ContainsKey(name) && overwrite == false)
        {
            throw new InvalidOperationException(
                $"An item named '{name}' already exists. Set overwrite to true to replace it.");
        }

        _data[name] = data!;

        WriteToFile();
    }

    private void WriteToFile()
    {
        string? directory = Path.GetDirectoryName(_filePath);

        if (!string.IsNullOrWhiteSpace(directory) && !Directory.Exists(directory))
        {
            Directory.CreateDirectory(directory);
        }

        string json = JsonConvert.SerializeObject(_data, Settings);

        File.WriteAllText(_filePath, json);
    }

    public T? Get<T>(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            throw new ArgumentException("Name cannot be null or empty.", nameof(name));

        if (!_data.ContainsKey(name))
            throw new KeyNotFoundException($"No item named '{name}' exists in the JSON file.");

        object value = _data[name];

        if (value is T typedValue)
            return typedValue;

        string json = JsonConvert.SerializeObject(value, Settings);

        return JsonConvert.DeserializeObject<T>(json, Settings);
    }

    public bool TryGet<T>(string name, out T? value)
    {
        value = default;

        if (string.IsNullOrWhiteSpace(name))
            return false;

        if (!_data.TryGetValue(name, out object? rawValue))
            return false;

        try
        {
            if (rawValue is T typedValue)
            {
                value = typedValue;
                return true;
            }

            string json = JsonConvert.SerializeObject(rawValue, Settings);
            value = JsonConvert.DeserializeObject<T>(json, Settings);

            return true;
        }
        catch
        {
            value = default;
            return false;
        }
    }

    public bool Contains(string name)
    {
        return _data.ContainsKey(name);
    }

    public void Remove(string name)
    {
        if (_data.Remove(name))
        {
            WriteToFile();
        }
    }

    public void Clear()
    {
        _data.Clear();
        WriteToFile();
    }

    public string FilePath => _filePath;
}