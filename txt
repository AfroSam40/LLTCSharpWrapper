private sealed class PolynomialFit
{
    public double[] Coefficients { get; set; } = Array.Empty<double>();
    public double XCenter { get; set; }
    public double XScale { get; set; }
}

private static PolynomialFit FitPolynomialNormalized(
    double[] x,
    double[] y,
    int degree)
{
    if (x == null || y == null)
        throw new ArgumentNullException();

    if (x.Length != y.Length)
        throw new ArgumentException("X and Y arrays must have the same length.");

    if (x.Length < degree + 1)
        throw new ArgumentException("Not enough points for requested polynomial degree.");

    if (degree < 1)
        throw new ArgumentOutOfRangeException(nameof(degree));

    double xMin = x.Min();
    double xMax = x.Max();
    double xCenter = 0.5 * (xMin + xMax);
    double xScale = 0.5 * (xMax - xMin);

    if (Math.Abs(xScale) < 1e-12)
        xScale = 1.0;

    int n = x.Length;
    int m = degree + 1;

    // Normal equations:
    // A^T A c = A^T y
    double[,] ata = new double[m, m];
    double[] aty = new double[m];

    for (int i = 0; i < n; i++)
    {
        double xn = (x[i] - xCenter) / xScale;

        double[] powers = new double[m];
        powers[0] = 1.0;

        for (int p = 1; p < m; p++)
            powers[p] = powers[p - 1] * xn;

        for (int row = 0; row < m; row++)
        {
            aty[row] += powers[row] * y[i];

            for (int col = 0; col < m; col++)
                ata[row, col] += powers[row] * powers[col];
        }
    }

    double[] coeffs = SolveLinearSystem(ata, aty);

    return new PolynomialFit
    {
        Coefficients = coeffs,
        XCenter = xCenter,
        XScale = xScale
    };
}

private static double EvaluatePolynomialNormalized(
    PolynomialFit fit,
    double x)
{
    double xn = (x - fit.XCenter) / fit.XScale;

    // Horner evaluation
    double y = 0.0;

    for (int i = fit.Coefficients.Length - 1; i >= 0; i--)
        y = y * xn + fit.Coefficients[i];

    return y;
}

private static double[] SolveLinearSystem(
    double[,] a,
    double[] b)
{
    int n = b.Length;

    double[,] m = new double[n, n + 1];

    for (int r = 0; r < n; r++)
    {
        for (int c = 0; c < n; c++)
            m[r, c] = a[r, c];

        m[r, n] = b[r];
    }

    // Gaussian elimination with partial pivoting
    for (int pivot = 0; pivot < n; pivot++)
    {
        int bestRow = pivot;
        double bestAbs = Math.Abs(m[pivot, pivot]);

        for (int r = pivot + 1; r < n; r++)
        {
            double abs = Math.Abs(m[r, pivot]);

            if (abs > bestAbs)
            {
                bestAbs = abs;
                bestRow = r;
            }
        }

        if (bestAbs < 1e-12)
            throw new InvalidOperationException("Polynomial fit matrix is singular.");

        if (bestRow != pivot)
        {
            for (int c = pivot; c <= n; c++)
            {
                double temp = m[pivot, c];
                m[pivot, c] = m[bestRow, c];
                m[bestRow, c] = temp;
            }
        }

        double pivotValue = m[pivot, pivot];

        for (int c = pivot; c <= n; c++)
            m[pivot, c] /= pivotValue;

        for (int r = 0; r < n; r++)
        {
            if (r == pivot)
                continue;

            double factor = m[r, pivot];

            for (int c = pivot; c <= n; c++)
                m[r, c] -= factor * m[pivot, c];
        }
    }

    double[] x = new double[n];

    for (int i = 0; i < n; i++)
        x[i] = m[i, n];

    return x;
}