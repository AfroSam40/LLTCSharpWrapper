public bool ContainsInlierXY(
    ScanPointXYZ point,
    double xyTolerance = 0.01)
{
    if (InlierPoints == null || InlierPoints.Count == 0)
        return false;

    double xyTolSq = xyTolerance * xyTolerance;

    foreach (var p in InlierPoints)
    {
        double dx = p.X - point.X;
        double dy = p.Y - point.Y;

        if ((dx * dx + dy * dy) <= xyTolSq)
            return true;
    }

    return false;
}