FUNCTION F_ModbusFloatBE_ToReal : REAL
VAR_INPUT
    wHigh : WORD; // first Modbus register, lower address
    wLow  : WORD; // second Modbus register, higher address
END_VAR
VAR
    uConvert : U_DWORD_REAL;
END_VAR

uConvert.dwValue :=
    SHL(WORD_TO_DWORD(wHigh), 16) OR WORD_TO_DWORD(wLow);

F_ModbusFloatBE_ToReal := uConvert.rValue;