public static Vector3 WorldToPalletLocal(Vector3 worldPoint, PCP.Transform palletTransform)
{
    var t = palletTransform.transformRaw;

    // World origin of pallet frame
    double ox = t.tx;
    double oy = t.ty;
    double oz = t.tz;

    // Remove translation first
    double dx = worldPoint.X - ox;
    double dy = worldPoint.Y - oy;
    double dz = worldPoint.Z - oz;

    // If transform uses scale, undo it before inverse rotation
    double s = Math.Abs(t.s) < 1e-12 ? 1.0 : t.s;
    dx /= s;
    dy /= s;
    dz /= s;

    /*
        Your forward transform is:

        world.X = r00*local.X + r01*local.Y + r02*local.Z + tx
        world.Y = r10*local.X + r11*local.Y + r12*local.Z + ty
        world.Z = r20*local.X + r21*local.Y + r22*local.Z + tz

        Therefore:

        world - origin = R * local

        For a rigid rotation matrix:

        local = R^T * (world - origin)
    */

    double lx = t.r00 * dx + t.r10 * dy + t.r20 * dz;
    double ly = t.r01 * dx + t.r11 * dy + t.r21 * dz;
    double lz = t.r02 * dx + t.r12 * dy + t.r22 * dz;

    return new Vector3((float)lx, (float)ly, (float)lz);
}