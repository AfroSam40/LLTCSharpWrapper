private static readonly Action<
    Index1D,
    ArrayView<ScanPointXYZ>,
    ArrayView<int>,
    ArrayView<RigidT>,
    ArrayView<ScanPointXYZ>> _stitchBetweenScansKernel =
        _acc.LoadAutoGroupedStreamKernel<
            Index1D,
            ArrayView<ScanPointXYZ>,
            ArrayView<int>,
            ArrayView<RigidT>,
            ArrayView<ScanPointXYZ>>(StitchBetweenScansKernel);

private static void StitchBetweenScansKernel(
    Index1D i,
    ArrayView<ScanPointXYZ> src,
    ArrayView<int> scanIndexPerPoint,
    ArrayView<RigidT> transforms,
    ArrayView<ScanPointXYZ> dst)
{
    if (i >= src.Length)
        return;

    var p = src[i];
    int scanIndex = scanIndexPerPoint[i];

    // scan 0 uses identity transform
    var rt = transforms[scanIndex];

    double x = p.X;
    double y = p.Y;
    double z = p.Z;
    double s = rt.s;

    dst[i] = new ScanPointXYZ(
        s * (rt.r00 * x + rt.r01 * y + rt.r02 * z) + rt.tx,
        s * (rt.r10 * x + rt.r11 * y + rt.r12 * z) + rt.ty,
        s * (rt.r20 * x + rt.r21 * y + rt.r22 * z) + rt.tz);
}

private static PointCloud StitchBetweenScans_GPU(List<PointCloud> scans)
{
    if (scans == null)
        throw new ArgumentNullException(nameof(scans));

    if (scans.Count == 0)
        return new PointCloud(Array.Empty<ScanPointXYZ>());

    if (scans.Count == 1)
        return scans[0].Clone();

    if (scansTransform == null)
        throw new InvalidOperationException("scansTransform is null.");

    if (scansTransform.Length < scans.Count - 1)
        throw new InvalidOperationException("scansTransform must contain at least scans.Count - 1 transforms.");

    int totalCount = 0;

    for (int s = 0; s < scans.Count; s++)
    {
        if (scans[s]?.Points == null)
            throw new InvalidOperationException($"Scan {s} or its Points list is null.");

        totalCount += scans[s].Points.Count;
    }

    if (totalCount == 0)
        return new PointCloud(Array.Empty<ScanPointXYZ>());

    var allPoints = new ScanPointXYZ[totalCount];
    var scanIndexPerPoint = new int[totalCount];

    int offset = 0;

    for (int s = 0; s < scans.Count; s++)
    {
        var pts = scans[s].Points;

        for (int i = 0; i < pts.Count; i++)
        {
            allPoints[offset + i] = pts[i];
            scanIndexPerPoint[offset + i] = s;
        }

        offset += pts.Count;
    }

    var transforms = new RigidT[scans.Count];

    transforms[0] = new RigidT
    {
        r00 = 1, r01 = 0, r02 = 0,
        r10 = 0, r11 = 1, r12 = 0,
        r20 = 0, r21 = 0, r22 = 1,
        tx = 0, ty = 0, tz = 0,
        s = 1
    };

    for (int s = 1; s < scans.Count; s++)
    {
        var tr = scansTransform[s - 1].transformRaw;

        transforms[s] = ToRigidT(
            tr.r00, tr.r01, tr.r02,
            tr.r10, tr.r11, tr.r12,
            tr.r20, tr.r21, tr.r22,
            tr.tx, tr.ty, tr.tz,
            tr.s);
    }

    using var dSrc = _acc.Allocate1D(allPoints);
    using var dScanIndex = _acc.Allocate1D(scanIndexPerPoint);
    using var dTransforms = _acc.Allocate1D(transforms);
    using var dDst = _acc.Allocate1D<ScanPointXYZ>(totalCount);

    _stitchBetweenScansKernel(
        totalCount,
        dSrc.View,
        dScanIndex.View,
        dTransforms.View,
        dDst.View);

    _acc.Synchronize();

    ScanPointXYZ[] stitchedPoints = dDst.GetAsArray1D();

    return new PointCloud(stitchedPoints);
}