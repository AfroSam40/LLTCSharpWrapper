using System;
using System.Data;
using System.Globalization;
using System.Text;
using System.Windows;

public static void CopyDataTableToClipboard(
    DataTable table,
    bool includeHeaders = true)
{
    if (table == null)
        throw new ArgumentNullException(nameof(table));

    var sb = new StringBuilder();

    if (includeHeaders)
    {
        for (int c = 0; c < table.Columns.Count; c++)
        {
            if (c > 0)
                sb.Append('\t');

            sb.Append(CleanForExcel(table.Columns[c].ColumnName));
        }

        sb.AppendLine();
    }

    foreach (DataRow row in table.Rows)
    {
        for (int c = 0; c < table.Columns.Count; c++)
        {
            if (c > 0)
                sb.Append('\t');

            object value = row[c];

            string text = value == DBNull.Value || value == null
                ? ""
                : Convert.ToString(value, CultureInfo.InvariantCulture);

            sb.Append(CleanForExcel(text));
        }

        sb.AppendLine();
    }

    Clipboard.SetText(sb.ToString(), TextDataFormat.UnicodeText);
}

private static string CleanForExcel(string text)
{
    if (string.IsNullOrEmpty(text))
        return "";

    // Prevent breaking Excel columns/rows
    return text
        .Replace("\t", " ")
        .Replace("\r\n", " ")
        .Replace("\r", " ")
        .Replace("\n", " ");
}