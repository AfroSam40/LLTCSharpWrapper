public sealed class LineVerticalSample
{
    public int Index { get; set; }
    public double DistanceAlongLine { get; set; }

    // Point on requested line at this increment
    public ScanPointXYZ LinePoint { get; set; }

    // Closest cloud point in XY
    public ScanPointXYZ ClosestPoint { get; set; }

    // XY distance from LinePoint to ClosestPoint
    public double ClosestXYDistance { get; set; }

    // Signed vertical difference: cloud Z - line Z
    public double VerticalDistance { get; set; }

    public bool Found { get; set; }
}

public sealed class LineVerticalProfileResult
{
    public List<LineVerticalSample> Samples { get; set; } = new();

    // Use this to draw/show the sampled line points
    public PointCloud LineCloud { get; set; } = new();

    // Use this to draw/show the closest cloud points
    public PointCloud ClosestCloud { get; set; } = new();
}

public static LineVerticalProfileResult MeasureVerticalDistanceAlongLine(
    PointCloud cloud,
    ScanPointXYZ start,
    ScanPointXYZ end,
    double increment,
    double maxSearchRadiusXY = 1.0)
{
    if (cloud == null)
        throw new ArgumentNullException(nameof(cloud));

    if (cloud.Points == null || cloud.Points.Count == 0)
        throw new ArgumentException("Point cloud is empty.", nameof(cloud));

    if (increment <= 0)
        throw new ArgumentOutOfRangeException(nameof(increment), "Increment must be greater than zero.");

    var result = new LineVerticalProfileResult();

    double dx = end.X - start.X;
    double dy = end.Y - start.Y;
    double dz = end.Z - start.Z;

    double lineLength = Math.Sqrt(dx * dx + dy * dy + dz * dz);

    if (lineLength <= 1e-9)
        throw new ArgumentException("Start and end points are the same.");

    int sampleCount = (int)Math.Floor(lineLength / increment) + 1;

    double maxRadiusSq = maxSearchRadiusXY * maxSearchRadiusXY;

    for (int i = 0; i <= sampleCount; i++)
    {
        double dist = i * increment;
        if (dist > lineLength)
            dist = lineLength;

        double t = dist / lineLength;

        var linePt = new ScanPointXYZ(
            start.X + dx * t,
            start.Y + dy * t,
            start.Z + dz * t);

        result.LineCloud.Points.Add(linePt);

        ScanPointXYZ closest = default;
        bool found = false;
        double bestDistSq = double.PositiveInfinity;

        foreach (var p in cloud.Points)
        {
            double px = p.X - linePt.X;
            double py = p.Y - linePt.Y;

            double dxySq = px * px + py * py;

            if (dxySq < bestDistSq)
            {
                bestDistSq = dxySq;
                closest = p;
                found = true;
            }
        }

        if (!found || bestDistSq > maxRadiusSq)
        {
            result.Samples.Add(new LineVerticalSample
            {
                Index = i,
                DistanceAlongLine = dist,
                LinePoint = linePt,
                Found = false,
                ClosestXYDistance = double.NaN,
                VerticalDistance = double.NaN
            });

            continue;
        }

        double closestXY = Math.Sqrt(bestDistSq);
        double verticalDistance = closest.Z - linePt.Z;

        result.ClosestCloud.Points.Add(closest);

        result.Samples.Add(new LineVerticalSample
        {
            Index = i,
            DistanceAlongLine = dist,
            LinePoint = linePt,
            ClosestPoint = closest,
            Found = true,
            ClosestXYDistance = closestXY,
            VerticalDistance = verticalDistance
        });
    }

    return result;
}


var profile = MeasureVerticalDistanceAlongLine(
    cloud: finalCloud,
    start: new ScanPointXYZ(100, 200, 0),
    end: new ScanPointXYZ(300, 200, 0),
    increment: 1.0,
    maxSearchRadiusXY: 0.5);

foreach (var s in profile.Samples)
{
    if (!s.Found)
        continue;

    Debug.Print(
        $"S={s.DistanceAlongLine:F3}, " +
        $"Line=({s.LinePoint.X:F3},{s.LinePoint.Y:F3},{s.LinePoint.Z:F3}), " +
        $"Closest=({s.ClosestPoint.X:F3},{s.ClosestPoint.Y:F3},{s.ClosestPoint.Z:F3}), " +
        $"XYDist={s.ClosestXYDistance:F3}, " +
        $"Vertical={s.VerticalDistance:F3}");
}