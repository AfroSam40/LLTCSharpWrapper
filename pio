using System;
using System.Collections.Generic;
using System.Linq;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;
using System.Windows.Shapes;

public static void ShowVerticalProfilePopup(
    LineVerticalProfileResult profile,
    string title = "Vertical Distance Profile")
{
    if (profile == null)
        throw new ArgumentNullException(nameof(profile));

    var samples = profile.Samples
        .Where(s => s.Found && !double.IsNaN(s.VerticalDistance))
        .ToList();

    if (samples.Count == 0)
    {
        MessageBox.Show("No valid vertical samples found.", title);
        return;
    }

    Application.Current.Dispatcher.Invoke(() =>
    {
        var window = new Window
        {
            Title = title,
            Width = 1000,
            Height = 650,
            WindowStartupLocation = WindowStartupLocation.CenterScreen
        };

        var grid = new Grid();
        grid.RowDefinitions.Add(new RowDefinition { Height = new GridLength(45) });
        grid.RowDefinitions.Add(new RowDefinition { Height = new GridLength(1, GridUnitType.Star) });
        grid.RowDefinitions.Add(new RowDefinition { Height = new GridLength(180) });

        double minZ = samples.Min(s => s.VerticalDistance);
        double maxZ = samples.Max(s => s.VerticalDistance);
        double avgZ = samples.Average(s => s.VerticalDistance);

        var header = new TextBlock
        {
            Text =
                $"Samples: {samples.Count}    " +
                $"Min: {minZ:F4}    " +
                $"Max: {maxZ:F4}    " +
                $"Avg: {avgZ:F4}",
            FontSize = 16,
            FontWeight = FontWeights.Bold,
            Margin = new Thickness(10),
            VerticalAlignment = VerticalAlignment.Center
        };

        Grid.SetRow(header, 0);
        grid.Children.Add(header);

        var canvas = new Canvas
        {
            Background = Brushes.White,
            Margin = new Thickness(10)
        };

        Grid.SetRow(canvas, 1);
        grid.Children.Add(canvas);

        var table = new DataGrid
        {
            Margin = new Thickness(10),
            AutoGenerateColumns = false,
            IsReadOnly = true,
            ItemsSource = samples.Select(s => new
            {
                s.Index,
                Distance = Math.Round(s.DistanceAlongLine, 4),
                LineX = Math.Round(s.LinePoint.X, 4),
                LineY = Math.Round(s.LinePoint.Y, 4),
                LineZ = Math.Round(s.LinePoint.Z, 4),
                ClosestX = Math.Round(s.ClosestPoint.X, 4),
                ClosestY = Math.Round(s.ClosestPoint.Y, 4),
                ClosestZ = Math.Round(s.ClosestPoint.Z, 4),
                XYError = Math.Round(s.ClosestXYDistance, 4),
                Vertical = Math.Round(s.VerticalDistance, 4)
            }).ToList()
        };

        table.Columns.Add(new DataGridTextColumn { Header = "Index", Binding = new System.Windows.Data.Binding("Index") });
        table.Columns.Add(new DataGridTextColumn { Header = "Dist", Binding = new System.Windows.Data.Binding("Distance") });
        table.Columns.Add(new DataGridTextColumn { Header = "Line X", Binding = new System.Windows.Data.Binding("LineX") });
        table.Columns.Add(new DataGridTextColumn { Header = "Line Y", Binding = new System.Windows.Data.Binding("LineY") });
        table.Columns.Add(new DataGridTextColumn { Header = "Line Z", Binding = new System.Windows.Data.Binding("LineZ") });
        table.Columns.Add(new DataGridTextColumn { Header = "Cloud X", Binding = new System.Windows.Data.Binding("ClosestX") });
        table.Columns.Add(new DataGridTextColumn { Header = "Cloud Y", Binding = new System.Windows.Data.Binding("ClosestY") });
        table.Columns.Add(new DataGridTextColumn { Header = "Cloud Z", Binding = new System.Windows.Data.Binding("ClosestZ") });
        table.Columns.Add(new DataGridTextColumn { Header = "XY Err", Binding = new System.Windows.Data.Binding("XYError") });
        table.Columns.Add(new DataGridTextColumn { Header = "Vertical", Binding = new System.Windows.Data.Binding("Vertical") });

        Grid.SetRow(table, 2);
        grid.Children.Add(table);

        canvas.SizeChanged += (_, _) => DrawVerticalProfile(canvas, samples);

        window.Content = grid;
        window.Show();
    });
}

private static void DrawVerticalProfile(
    Canvas canvas,
    List<LineVerticalSample> samples)
{
    canvas.Children.Clear();

    if (samples == null || samples.Count < 2)
        return;

    double width = canvas.ActualWidth;
    double height = canvas.ActualHeight;

    if (width <= 20 || height <= 20)
        return;

    double left = 70;
    double right = 25;
    double top = 25;
    double bottom = 55;

    double plotW = width - left - right;
    double plotH = height - top - bottom;

    double minX = samples.Min(s => s.DistanceAlongLine);
    double maxX = samples.Max(s => s.DistanceAlongLine);

    double minY = samples.Min(s => s.VerticalDistance);
    double maxY = samples.Max(s => s.VerticalDistance);

    if (Math.Abs(maxY - minY) < 1e-9)
    {
        maxY += 0.5;
        minY -= 0.5;
    }

    double yPad = (maxY - minY) * 0.10;
    minY -= yPad;
    maxY += yPad;

    double MapX(double x)
    {
        return left + ((x - minX) / (maxX - minX)) * plotW;
    }

    double MapY(double y)
    {
        return top + (1.0 - ((y - minY) / (maxY - minY))) * plotH;
    }

    // Plot border
    canvas.Children.Add(new Rectangle
    {
        Width = plotW,
        Height = plotH,
        Stroke = Brushes.Black,
        StrokeThickness = 1
    });

    Canvas.SetLeft(canvas.Children[^1], left);
    Canvas.SetTop(canvas.Children[^1], top);

    // Zero line
    if (minY <= 0 && maxY >= 0)
    {
        double y0 = MapY(0);

        canvas.Children.Add(new Line
        {
            X1 = left,
            Y1 = y0,
            X2 = left + plotW,
            Y2 = y0,
            Stroke = Brushes.Gray,
            StrokeThickness = 1,
            StrokeDashArray = new DoubleCollection { 4, 4 }
        });
    }

    // Polyline profile
    var polyline = new Polyline
    {
        Stroke = Brushes.Blue,
        StrokeThickness = 2
    };

    foreach (var s in samples)
    {
        polyline.Points.Add(new Point(
            MapX(s.DistanceAlongLine),
            MapY(s.VerticalDistance)));
    }

    canvas.Children.Add(polyline);

    // Sample points
    foreach (var s in samples)
    {
        double x = MapX(s.DistanceAlongLine);
        double y = MapY(s.VerticalDistance);

        var dot = new Ellipse
        {
            Width = 5,
            Height = 5,
            Fill = Brushes.Red
        };

        Canvas.SetLeft(dot, x - 2.5);
        Canvas.SetTop(dot, y - 2.5);
        canvas.Children.Add(dot);
    }

    // Axis labels
    AddCanvasText(canvas, "Distance Along Line", left + plotW / 2 - 60, height - 35, 13, Brushes.Black);
    AddCanvasText(canvas, "Vertical Distance", 8, top + plotH / 2 - 10, 13, Brushes.Black);

    AddCanvasText(canvas, minX.ToString("F2"), left - 10, height - bottom + 8, 12, Brushes.Black);
    AddCanvasText(canvas, maxX.ToString("F2"), left + plotW - 25, height - bottom + 8, 12, Brushes.Black);

    AddCanvasText(canvas, maxY.ToString("F3"), 10, top - 8, 12, Brushes.Black);
    AddCanvasText(canvas, minY.ToString("F3"), 10, top + plotH - 8, 12, Brushes.Black);
}

private static void AddCanvasText(
    Canvas canvas,
    string text,
    double x,
    double y,
    double fontSize,
    Brush brush)
{
    var tb = new TextBlock
    {
        Text = text,
        FontSize = fontSize,
        Foreground = brush
    };

    Canvas.SetLeft(tb, x);
    Canvas.SetTop(tb, y);
    canvas.Children.Add(tb);
}